{
    "name": "tlb/umami-bundle",
    "description": "Symfony bundle for Umami v3 tracking, events, and API access.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "umami",
        "analytics"
    ],
    "require": {
        "php": "^8.2",
        "symfony/config": "^6.4 || ^7.1 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.1 || ^8.0",
        "symfony/http-client": "^6.4 || ^7.1 || ^8.0",
        "symfony/http-kernel": "^6.4 || ^7.1 || ^8.0",
        "symfony/twig-bundle": "^6.4 || ^7.1 || ^8.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.5 || ^12.0 || ^13.0",
        "symfony/cache": "^6.4 || ^7.1 || ^8.0",
        "symfony/dotenv": "^6.4 || ^7.1 || ^8.0",
        "symfony/framework-bundle": "^6.4 || ^7.1 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Tlb\\UmamiBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tlb\\UmamiBundle\\Tests\\": "tests/UmamiBundle/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
